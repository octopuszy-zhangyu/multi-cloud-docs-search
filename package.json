{
  "name": "multi-cloud-docs-search",
  "version": "1.3.14",
  "description": "MCP Server for multi-cloud provider documentation search — search and retrieve official cloud vendor docs directly in AI coding assistants",
  "keywords": [
    "mcp",
    "mcp-server",
    "multi-cloud",
    "documentation",
    "cloud-provider",
    "ctyun",
    "aliyun",
    "volcengine",
    "tencent",
    "huawei",
    "ecloud",
    "cucloud",
    "baidu",
    "deepseek",
    "glm",
    "minimax",
    "kimi",
    "ai-assistant",
    "claude-code",
    "cursor",
    "windsurf"
  ],
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/stdio.js",
  "bin": {
    "multi-cloud-docs-search": "bin/cli.js"
  },
  "scripts": {
    "start": "node dist/stdio.js",
    "dev": "npx tsx watch src/stdio.ts",
    "build": "npx tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "cheerio": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250301.0",
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
